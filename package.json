{
  "name": "@mikaelcedergren/cx-framework",
  "version": "0.1.0",
  "description": "Personal Angular UI framework shared by Cortex apps.",
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "main": "./dist/lib/public-api.js",
  "module": "./dist/lib/public-api.js",
  "types": "./dist/lib/public-api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/public-api.d.ts",
      "default": "./dist/lib/public-api.js"
    },
    "./DESIGN-SYSTEM.md": "./DESIGN-SYSTEM.md",
    "./icons/*": "./icons/*",
    "./package.json": "./package.json",
    "./patterns/*": "./patterns/*",
    "./primitives/*": "./primitives/*",
    "./styles/*": {
      "sass": "./styles/_*.scss",
      "default": "./styles/_*.scss"
    },
    "./support/*": "./support/*",
    "./tokens": {
      "sass": "./tokens/index.scss",
      "default": "./tokens/index.scss"
    },
    "./tokens/*": {
      "sass": "./tokens/_*.scss",
      "default": "./tokens/_*.scss"
    },
    "./tooling/*": "./tooling/*"
  },
  "files": [
    "DESIGN-SYSTEM.md",
    "dist/",
    "icons/",
    "patterns/",
    "primitives/",
    "scripts/",
    "styles/",
    "support/",
    "tokens/",
    "tooling/",
    "public-api.ts",
    "tsconfig.lib.json"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "icons": "node scripts/generate-icon-manifest.mjs",
    "prepare": "node scripts/build.mjs"
  },
  "dependencies": {
    "marked": "^18.0.2",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@angular/cdk": "^21.0.5",
    "@angular/common": "^21.0.7",
    "@angular/core": "^21.0.7",
    "@angular/router": "^21.0.7",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@angular/compiler": "^21.0.7",
    "@angular/compiler-cli": "^21.0.7",
    "ng-packagr": "^21.0.0",
    "typescript": "~5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikaelcedergren/cx-framework.git"
  },
  "bugs": {
    "url": "https://github.com/mikaelcedergren/cx-framework/issues"
  },
  "homepage": "https://github.com/mikaelcedergren/cx-framework#readme",
  "sideEffects": [
    "**/*.scss"
  ]
}
