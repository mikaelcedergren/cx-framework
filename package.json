{
  "name": "@mikaelcedergren/cx-framework",
  "version": "0.3.3",
  "description": "Personal Angular UI framework and AI design package.",
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "main": "./dist/lib/public-api.js",
  "module": "./dist/lib/public-api.js",
  "types": "./dist/lib/public-api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/public-api.d.ts",
      "default": "./dist/lib/public-api.js"
    },
    "./DESIGN-SYSTEM.md": "./DESIGN-SYSTEM.md",
    "./PACKAGING.md": "./PACKAGING.md",
    "./README.md": "./README.md",
    "./package.json": "./package.json",
    "./ai/*": "./ai/*",
    "./fonts/*": "./fonts/*",
    "./icons/*": "./icons/*",
    "./patterns/*": "./patterns/*",
    "./primitives/*": "./primitives/*",
    "./scripts/*": "./scripts/*",
    "./styles/*": {
      "sass": "./styles/_*.scss",
      "default": "./styles/_*.scss"
    },
    "./support/*": "./support/*",
    "./tokens": {
      "sass": "./tokens/index.scss",
      "default": "./tokens/index.scss"
    },
    "./tokens/*": {
      "sass": "./tokens/_*.scss",
      "default": "./tokens/_*.scss"
    },
    "./tooling/*": "./tooling/*"
  },
  "files": [
    "README.md",
    "PACKAGING.md",
    "DESIGN-SYSTEM.md",
    "dist/",
    "ai/",
    "fonts/",
    "icons/",
    "patterns/",
    "primitives/",
    "public-api.ts",
    "scripts/",
    "styles/",
    "support/",
    "tokens/",
    "tooling/",
    "tsconfig.lib.json"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "icons": "node scripts/generate-icon-manifest.mjs",
    "icons:check": "node scripts/generate-icon-index.mjs --check",
    "icons:index": "node scripts/generate-icon-index.mjs",
    "prepare": "node scripts/build.mjs"
  },
  "dependencies": {
    "ag-charts-community": "^13.3.1",
    "marked": "^18.0.2",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "ng-packagr": "^22.0.0",
    "rxjs": "^7.8.0",
    "sass": "^1.101.0",
    "typescript": "~6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikaelcedergren/cx-framework.git"
  },
  "bugs": {
    "url": "https://github.com/mikaelcedergren/cx-framework/issues"
  },
  "homepage": "https://github.com/mikaelcedergren/cx-framework#readme",
  "sideEffects": [
    "**/*.scss"
  ]
}
